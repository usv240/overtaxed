# ── Copy this file to `.env` and fill in real values. NEVER commit `.env`. ──

# ClickHouse Cloud (PRIMARY DATABASE)
# From the ClickHouse Cloud console → your service → "Connect".
CLICKHOUSE_HOST=https://xxxxxxxx.region.provider.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=overtaxed

# Trigger.dev (ORCHESTRATION — chat.agent())
# Project ref is already known from the hackathon setup.
TRIGGER_PROJECT_REF=proj_tscqzltxigwvlihuprmk
# Dev secret key from the Trigger.dev dashboard (starts tr_dev_...)
TRIGGER_SECRET_KEY=
# Personal Access Token (starts tr_pat_...) — only if not using `trigger.dev login`
TRIGGER_ACCESS_TOKEN=

# LLM (the agent's brain)
ANTHROPIC_API_KEY=

# Postgres / Supabase (OLTP+OLAP bonus — needed ~Day 5)
DATABASE_URL=

# Public app URL (set on deploy — Day 6)
NEXT_PUBLIC_APP_URL=http://localhost:3000
